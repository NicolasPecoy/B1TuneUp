<Window x:Class="B1TuneUp.Modules.BarcodeScannerUi.BarcodeScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B1TuneUp - Barcode Scanner"
        Width="420"
        Height="220"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B1TuneUp;component/Resources/B1Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <StackPanel>
            <TextBlock Text="Target Item ID" Style="{StaticResource LabelTextBlockStyle}" />
            <TextBox Text="{Binding TargetItemId, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Valor escaneado" Style="{StaticResource LabelTextBlockStyle}" />
            <TextBox Text="{Binding ScannedValue, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Insertar en SAP" Width="160" Command="{Binding InjectCommand}" />
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>
    </Border>
</Window>
