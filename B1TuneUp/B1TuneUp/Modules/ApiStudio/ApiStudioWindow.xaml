<Window x:Class="B1TuneUp.Modules.ApiStudio.ApiStudioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:api="clr-namespace:B1TuneUp.Modules.ApiStudio"
        Title="B1TuneUp API Studio"
        Width="1360"
        Height="820"
        MinWidth="1180"
        MinHeight="700"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F3F6FA</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="72" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type api:ApiCollection}" ItemsSource="{Binding Requests}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="COL" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentAltBrush}" Width="30" />
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type api:ApiRequest}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Method}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Width="44" />
                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,18" CornerRadius="0,0,18,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="B1TuneUp API Studio" Foreground="White" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="Colecciones, ambientes, historial, debugging y pruebas Service Layer."
                               Foreground="#DDFFFFFF" FontSize="13" Margin="0,5,0,0" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#DDFFFFFF" FontSize="12" Margin="0,7,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Ambiente activo" Foreground="#DDFFFFFF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Environments}"
                              SelectedItem="{Binding SelectedEnvironment}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="315" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Colecciones" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBox Grid.Row="1"
                             Margin="0,10,0,0"
                             Text="{Binding CollectionSearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Buscar colecciones o requests dentro del arbol" />
                    <TreeView Grid.Row="2"
                              Margin="0,12,0,12"
                              ItemsSource="{Binding FilteredCollections}"
                              SelectedItemChanged="OnTreeSelectedItemChanged"
                              BorderBrush="{DynamicResource BorderBrush}"
                              Background="{DynamicResource SurfaceAltBrush}" />

                    <TextBlock Grid.Row="3" Text="Buscar requests" Style="{StaticResource LabelStyle}" />
                    <TextBox Grid.Row="3" Margin="0,20,0,8" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <ListBox Grid.Row="4"
                             ItemsSource="{Binding SearchResults}"
                             SelectedValuePath="Request"
                             MouseDoubleClick="OnSearchResultDoubleClick"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Background="{DynamicResource SurfaceAltBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Url}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <WrapPanel Grid.Row="5" Margin="0,12,0,0">
                        <Button Content="Coleccion" Command="{Binding NewCollectionCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Request" Command="{Binding NewRequestCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Duplicar" Command="{Binding DuplicateRequestCommand}" Background="{DynamicResource PrimaryBrush}" />
                        <Button Content="Eliminar" Command="{Binding DeleteSelectedCommand}" Background="#B33939" />
                    </WrapPanel>
                </Grid>
            </Border>

            <TabControl Grid.Column="2">
                <TabItem Header="Request / Response">
            <Grid Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="92" />
                        </Grid.ColumnDefinitions>

                        <ComboBox ItemsSource="{Binding Methods}"
                                  Text="{Binding SelectedRequest.Method, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" />
                        <TextBox Grid.Column="1" Margin="8,0" Text="{Binding SelectedRequest.Url, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2" Content="Enviar" Command="{Binding SendCommand}" Background="{DynamicResource AccentBrush}" />
                        <Button Grid.Column="3" Content="Guardar" Command="{Binding SaveCommand}" Background="{DynamicResource PrimaryDarkBrush}" />

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="4" Text="{Binding PreviewUrl}" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <TabControl>
                        <TabItem Header="Request">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedRequest.Name, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Content-Type" Style="{StaticResource LabelStyle}" />
                                    <ComboBox ItemsSource="{Binding ContentTypes}"
                                              Text="{Binding SelectedRequest.ContentType, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10,0,8">
                                    <TextBlock Text="Headers" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedRequest.Headers, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="NoWrap"
                                             FontFamily="Consolas" FontSize="12"
                                             HorizontalScrollBarVisibility="Auto"
                                             VerticalScrollBarVisibility="Auto"
                                             Height="72" />
                                </StackPanel>

                                <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="Body" Style="{StaticResource LabelStyle}" />
                                <TextBox Grid.Row="2" Grid.ColumnSpan="3" Text="{Binding SelectedRequest.Body, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,20,0,0"
                                         AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                         FontFamily="Consolas" FontSize="12"
                                         HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                                <WrapPanel Grid.Row="3" Grid.ColumnSpan="3" Margin="0,10,0,0">
                                    <Button Content="Beautify JSON" Command="{Binding BeautifyRequestJsonCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Beautify XML" Command="{Binding BeautifyRequestXmlCommand}" Background="{DynamicResource AccentAltBrush}" />
                                </WrapPanel>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Descripcion">
                            <TextBox Text="{Binding SelectedRequest.Description, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </TabItem>
                    </TabControl>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                    <TabControl>
                        <TabItem Header="Respuesta">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding LastResponse.StatusCode}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="{Binding LastResponse.StatusDescription}" Margin="8,2,16,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding LastResponse.DurationMs, StringFormat={}{0} ms}" Margin="0,2,16,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding LastResponse.ResponseBytes, StringFormat={}{0} bytes}" Margin="0,2,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                                <TextBox Grid.Row="1" Text="{Binding LastResponse.Body, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,10,0,0" FontFamily="Consolas" FontSize="12"
                                         AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                         HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                                <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                    <Button Content="Beautify JSON" Command="{Binding BeautifyResponseJsonCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Beautify XML" Command="{Binding BeautifyResponseXmlCommand}" Background="{DynamicResource AccentAltBrush}" />
                                </WrapPanel>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Headers">
                            <TextBox Text="{Binding LastResponse.Headers}" Margin="0,10,0,0"
                                     FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                                     AcceptsReturn="True" TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                        </TabItem>
                        <TabItem Header="Debug">
                            <TextBox Text="{Binding LastResponse.DebugLog}" Margin="0,10,0,0"
                                     FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                                     AcceptsReturn="True" TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
                </TabItem>

                <TabItem Header="Ambientes">
            <Grid Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Variables de ambiente" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <DataGrid x:Name="VariablesGrid"
                                  Grid.Row="1"
                                  Margin="0,12,0,12"
                                  ItemsSource="{Binding SelectedEnvironment.Variables}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Background="{DynamicResource SurfaceAltBrush}">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="42" />
                                <DataGridTextColumn Header="Key" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="1.3*" />
                                <DataGridCheckBoxColumn Header="Secret" Binding="{Binding Secret}" Width="58" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <WrapPanel Grid.Row="2">
                            <Button Content="Ambiente" Command="{Binding NewEnvironmentCommand}" Background="{DynamicResource AccentAltBrush}" />
                            <Button Content="Variable" Command="{Binding AddVariableCommand}" Background="{DynamicResource AccentAltBrush}" />
                            <Button Content="Borrar var" Command="{Binding DeleteVariableCommand}" CommandParameter="{Binding SelectedItem, ElementName=VariablesGrid}" Background="#B33939" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
                </TabItem>

                <TabItem Header="Historial">
            <Grid Margin="0,10,0,0">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Historial avanzado" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <ListBox Grid.Row="1"
                                 Margin="0,12,0,12"
                                 ItemsSource="{Binding History}"
                                 SelectedItem="{Binding SelectedHistory}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Background="{DynamicResource SurfaceAltBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Method}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Width="52" />
                                            <TextBlock Text="{Binding StatusCode}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Width="46" />
                                            <TextBlock Text="{Binding DurationMs, StringFormat={}{0}ms}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding RequestName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Url}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <WrapPanel Grid.Row="2">
                            <Button Content="Ver" Command="{Binding LoadHistoryCommand}" Background="{DynamicResource PrimaryBrush}" />
                            <Button Content="Limpiar" Command="{Binding ClearHistoryCommand}" Background="#B33939" />
                            <Button Content="Seed SL" Command="{Binding InstallSeedCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,0,18,14">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cerrar" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="..." FontSize="24" HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
