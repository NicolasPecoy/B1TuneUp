<Window x:Class="B1TuneUp.Modules.PlacementEnhancementUi.PlacementEnhancementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Item Placement &amp; UI Enhancer"
        Width="1420"
        Height="820"
        MinWidth="1200"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp Item Placement &amp; UI Enhancer" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Administra layouts, item placement y mejoras visuales con el mismo estilo SAP Business One." Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#E6FFFFFF" FontSize="13" Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="24" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.6*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Layout list -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Biblioteca de layouts" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" DockPanel.Dock="Left" />
                                <Button Content="Refrescar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" HorizontalAlignment="Right" />
                            </DockPanel>
                            <TextBlock Text="Filtrar por formulario" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding LayoutFormFilter, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Buscar por nombre o descripcion" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding LayoutSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <ListView ItemsSource="{Binding LayoutsView}"
                                      SelectedItem="{Binding SelectedLayout}"
                                      Margin="0,8,0,0"
                                      Height="420"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      BorderThickness="1"
                                      Background="{DynamicResource SurfaceAltBrush}">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Formulario" DisplayMemberBinding="{Binding FormType}" Width="110" />
                                        <GridViewColumn Header="Layout" DisplayMemberBinding="{Binding LayoutName}" Width="160" />
                                        <GridViewColumn Header="Descripcion" DisplayMemberBinding="{Binding Description}" Width="220" />
                                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="70" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Layout operations -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Capturar o importar" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Estado del formulario activo" Style="{StaticResource LabelStyle}" Margin="0,12,0,4" />
                            <TextBlock Text="{Binding ActiveFormInfo}" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Button Content="Detectar formulario activo" Command="{Binding DetectActiveFormCommand}" Background="{DynamicResource AccentAltBrush}" />

                            <TextBlock Text="Tipo de formulario (manual opcional)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding ManualFormType, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Nombre del layout" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding NewLayoutName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Descripcion" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding NewLayoutDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="70" TextWrapping="Wrap" />

                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Guardar desde formulario" Command="{Binding SaveLayoutCommand}" />
                                <Button Content="Importar desde archivo" Command="{Binding ImportLayoutCommand}" Background="{DynamicResource AccentAltBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Layout seleccionado" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <StackPanel Orientation="Vertical" Margin="0,12,0,0">
                                <TextBlock Text="Formulario:" Style="{StaticResource LabelStyle}" Margin="0,0,0,0" />
                                <TextBlock Text="{Binding SelectedLayout.FormType}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="Layout:" Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedLayout.LayoutName}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="Descripcion:" Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedLayout.Description}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="Propietario:" Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedLayout.Owner}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Version/Fecha:" Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedLayout.MetadataLine}" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Aplicar al formulario" Command="{Binding ApplyLayoutCommand}" />
                                <Button Content="Exportar" Command="{Binding ExportLayoutCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteLayoutCommand}" Background="#FFB33939" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- UI enhancements -->
                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="UI Enhancements" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Acciones rapidas" Style="{StaticResource LabelStyle}" />
                        <WrapPanel>
                            <Button Content="Abrir Item Placement" Command="{Binding OpenPlacementCommand}" />
                            <Button Content="Drag &amp; Drop" Command="{Binding LaunchDragDropCommand}" Background="{DynamicResource AccentAltBrush}" />
                        </WrapPanel>

                        <TextBlock Text="Editor de texto" Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding RichTextItemId, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Abrir editor" Command="{Binding OpenRichTextCommand}" />

                        <TextBlock Text="Pivot de grilla" Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding PivotGridId, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Generar pivot" Command="{Binding OpenPivotCommand}" />

                        <TextBlock Text="Escaner de codigos" Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding BarcodeTargetId, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Iniciar escaner" Command="{Binding OpenBarcodeCommand}" />

                        <TextBlock Text="Dashboard SQL" Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding DashboardQuery, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                        <Button Content="Mostrar dashboard" Command="{Binding OpenDashboardCommand}" />

                        <TextBlock Text="Visual Designer" Style="{StaticResource LabelStyle}" />
                        <Button Content="Abrir disenador" Command="{Binding OpenDesignerCommand}" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.RowSpan="2"
                Background="#B3FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource SurfaceBrush}" Padding="24" CornerRadius="12" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Procesando..." Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
