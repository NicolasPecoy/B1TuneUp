<Window x:Class="B1TuneUp.Modules.LanguageSelectorUi.LanguageSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B1TuneUp - Language Selector"
        Width="400"
        Height="200"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B1TuneUp;component/Resources/B1Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <StackPanel>
            <TextBlock Text="Selecciona un idioma" Style="{StaticResource LabelTextBlockStyle}" />
            <ComboBox ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}" />
            <Button Content="Guardar" Width="120" Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0,12,0,0"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>
    </Border>
</Window>
