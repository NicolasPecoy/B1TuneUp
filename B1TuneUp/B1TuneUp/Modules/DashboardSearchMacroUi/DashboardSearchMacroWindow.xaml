<Window x:Class="B1TuneUp.Modules.DashboardSearchMacroUi.DashboardSearchMacroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Dashboard/Search/Macro Studio"
        Width="1320"
        Height="780"
        MinWidth="1200"
        MinHeight="700"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp - Dashboard / Search / Macro Studio" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Gestiona widgets, busquedas y macros con la misma experiencia visual de SAP Business One." Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Widgets column -->
                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Widgets del dashboard" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBox Text="{Binding WidgetSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <ListBox ItemsSource="{Binding WidgetsView}"
                                         SelectedItem="{Binding SelectedWidget}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         Height="260">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding WidgetType}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="Nuevo" Command="{Binding NewWidgetCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Duplicar" Command="{Binding DuplicateWidgetCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Eliminar" Command="{Binding DeleteWidgetCommand}" Background="#FFB33939" />
                                    <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Detalle del widget" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Nombre interno" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedWidget.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Titulo" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedWidget.Title, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Tipo" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedWidget.WidgetType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Consulta / Fuente" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedWidget.Query, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Ancho" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedWidget.Width, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Posicion" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedWidget.Position, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Alto" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedWidget.Height, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Color" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedWidget.Color, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                                <WrapPanel>
                                    <Button Content="Guardar widget" Command="{Binding SaveWidgetCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Search column -->
                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Busquedas configuradas" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBox Text="{Binding SearchSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <ListBox ItemsSource="{Binding SearchView}"
                                         SelectedItem="{Binding SelectedSearch}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         Height="260">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="Nueva" Command="{Binding NewSearchCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Duplicar" Command="{Binding DuplicateSearchCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Eliminar" Command="{Binding DeleteSearchCommand}" Background="#FFB33939" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Detalle de busqueda" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedSearch.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Descripcion" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedSearch.Description, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" />
                                <TextBlock Text="Consulta" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedSearch.Query, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" />
                                <TextBlock Text="Accion" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedSearch.Action, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" />
                                <WrapPanel>
                                    <Button Content="Guardar busqueda" Command="{Binding SaveSearchCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Macro column -->
                    <StackPanel Grid.Column="4">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Macros" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBox Text="{Binding MacroSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <ListBox ItemsSource="{Binding MacroView}"
                                         SelectedItem="{Binding SelectedMacro}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         Height="260">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="Nueva" Command="{Binding NewMacroCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Duplicar" Command="{Binding DuplicateMacroCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Eliminar" Command="{Binding DeleteMacroCommand}" Background="#FFB33939" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Detalle de macro" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedMacro.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Descripcion" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedMacro.Description, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" />
                                <TextBlock Text="Script" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedMacro.Source, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="160" FontFamily="Consolas" />
                                <TextBlock Text="Parametros" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedMacro.Parameters, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" />
                                <WrapPanel>
                                    <Button Content="Guardar macro" Command="{Binding SaveMacroCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Guardar todo" Command="{Binding SaveAllCommand}" Background="{DynamicResource PrimaryBrush}" />
            <Button Content="Cerrar" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="..." FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
