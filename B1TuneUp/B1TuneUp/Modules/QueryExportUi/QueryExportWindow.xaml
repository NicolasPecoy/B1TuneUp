<Window x:Class="B1TuneUp.Modules.QueryExportUi.QueryExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B1TuneUp · Query Exporter"
        Width="1024"
        Height="680"
        MinWidth="820"
        MinHeight="520"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B1TuneUp;component/B1TuneUp/Resources/B1Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextBlockStyle}">
                <Setter Property="Margin" Value="0,12,0,4" />
            </Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource B1TextBoxStyle}" />
            <Style TargetType="Button" BasedOn="{StaticResource B1PrimaryButtonStyle}">
                <Setter Property="Width" Value="200" />
            </Style>
            <Style TargetType="Border" BasedOn="{StaticResource B1CardBorderStyle}">
                <Setter Property="Padding" Value="24" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Query Exporter"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold" />
                <TextBlock Text="Captura la consulta del formulario activo y expórtala en el formato que necesites."
                           Foreground="#CCFFFFFF"
                           Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#CCFFFFFF"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Cargar desde formulario"
                            Command="{Binding LoadFromActiveFormCommand}" />
                </StackPanel>

                <TextBox Grid.Row="1"
                         Text="{Binding SqlText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="Wrap" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Exportar CSV" Command="{Binding ExportCsvCommand}" />
                    <Button Content="Exportar JSON" Margin="12,0,0,0" Command="{Binding ExportJsonCommand}" />
                    <Button Content="Exportar XML" Margin="12,0,0,0" Command="{Binding ExportXmlCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24,0,24,24">
            <Button Content="Cerrar"
                    Width="140"
                    Background="{DynamicResource PrimaryDarkBrush}"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>


