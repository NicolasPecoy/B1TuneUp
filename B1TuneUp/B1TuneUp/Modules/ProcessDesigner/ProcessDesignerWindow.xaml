<Window x:Class="B1TuneUp.Modules.ProcessDesigner.ProcessDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Process Designer"
        Width="1280"
        Height="780"
        MinWidth="1100"
        MinHeight="700"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,24,24,28" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Process Designer" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Diseña guías paso a paso (Process Steps) con un editor visual integrado."
                           Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Filtros" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding FormFilter, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Buscar" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}" />

                    <ListBox ItemsSource="{Binding Processes}"
                             SelectedItem="{Binding SelectedProcess}"
                             DisplayMemberPath="DisplayName"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Background="{DynamicResource SurfaceAltBrush}"
                             Height="420" />

                    <UniformGrid Rows="2" Columns="2" Margin="0,16,0,0">
                        <Button Content="Nuevo" Command="{Binding NewProcessCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Duplicar" Command="{Binding DuplicateProcessCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Eliminar" Command="{Binding DeleteProcessCommand}" Background="#FFB33939" />
                        <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedProcess.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedProcess.FormType, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <CheckBox Content="Activo" IsChecked="{Binding SelectedProcess.Active}" Margin="0,0,0,8" />
                                <CheckBox Content="Mostrar automáticamente" IsChecked="{Binding SelectedProcess.AutoShow}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding SelectedProcess.Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Pasos" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <ListBox ItemsSource="{Binding SelectedSteps}"
                                         SelectedItem="{Binding SelectedStep}"
                                         DisplayMemberPath="DisplayName"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Height="300" />
                                <UniformGrid Rows="1" Columns="3" Margin="0,12,0,0">
                                    <Button Content="Añadir" Command="{Binding AddStepCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Duplicar" Command="{Binding DuplicateStepCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Eliminar" Command="{Binding DeleteStepCommand}" Background="#FFB33939" />
                                </UniformGrid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Orden" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedStep.Order, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Nombre del paso" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedStep.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedStep.Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                                <TextBlock Text="Condición de completado (SQL)" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedStep.DoneCondition, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                                <TextBlock Text="Acción (macro)" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedStep.Action, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />
                                <CheckBox Content="Obligatorio" IsChecked="{Binding SelectedStep.Mandatory}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <WrapPanel>
                            <Button Content="Guardar" Command="{Binding SaveProcessCommand}" />
                        </WrapPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cerrar" Width="120" Background="{DynamicResource PrimaryDarkBrush}" Click="OnCloseClick" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⌛" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
