<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="RegistryComponent" Guid="*">
        <RegistryKey Root="HKLM" Key="SOFTWARE\SAP\SAP Business One\AddOns\$(var.AddonCode)">
          <RegistryValue Type="string" Name="Path" Value="[INSTALLFOLDER]B1TuneUp.exe" KeyPath="yes" />
          <RegistryValue Type="string" Name="Description" Value="B1TuneUp Addon" />
          <RegistryValue Type="string" Name="Version" Value="$(var.ProductVersion)" />
        </RegistryKey>
      </Component>
    </DirectoryRef>

    <ComponentGroup Id="B1TuneUpRegistry">
      <ComponentRef Id="RegistryComponent" />
    </ComponentGroup>
  </Fragment>
</Wix>
