<Window x:Class="B1TuneUp.Modules.ProcessStepsUi.ProcessStepsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:B1TuneUp.Modules.ProcessStepsUi"
        Title="B1TuneUp · Process Steps"
        Width="626"
        Height="649"
        MinWidth="540"
        MinHeight="440"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B1TuneUp;component/B1TuneUp/Resources/B1Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:ProcessStepStateConverter x:Key="ProcessStepStateConverter" />
            <local:MandatoryFlagConverter x:Key="MandatoryFlagConverter" />

            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextBlockStyle}">
                <Setter Property="Margin" Value="0,8,0,4" />
            </Style>
            <Style TargetType="Button" BasedOn="{StaticResource B1PrimaryButtonStyle}">
                <Setter Property="Width" Value="150" />
            </Style>
            <Style TargetType="Border" BasedOn="{StaticResource B1CardBorderStyle}">
                <Setter Property="Padding" Value="20" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="{Binding ProcessTitle}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding ProgressText}"
                           Foreground="#CCFFFFFF"
                           Margin="0,6,0,0" />
                <ProgressBar Value="{Binding ProgressValue}"
                             Height="10"
                             Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListView ItemsSource="{Binding Steps}"
                          SelectedItem="{Binding SelectedStep}"
                          Grid.Row="0"
                          Margin="0,0,0,12">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="40" DisplayMemberBinding="{Binding Order}" />
                            <GridViewColumn Header="Paso" Width="220" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Estado" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsDone, Converter={StaticResource ProcessStepStateConverter}}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Obligatorio" Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Mandatory, Converter={StaticResource MandatoryFlagConverter}}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border Grid.Row="1"
                        Padding="12"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding Description}"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
                    <Button Content="Ejecutar paso"
                            Command="{Binding ExecuteCommand}" />
                    <Button Content="Actualizar"
                            Width="130"
                            Margin="12,0,0,0"
                            Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24,0,24,24">
            <Button Content="Cerrar"
                    Width="140"
                    Background="{DynamicResource PrimaryDarkBrush}"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>


