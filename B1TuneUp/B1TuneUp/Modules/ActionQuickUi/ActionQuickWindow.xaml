<Window x:Class="B1TuneUp.Modules.ActionQuickUi.ActionQuickWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Action Pad / Quick Copy / Item Actions"
        Width="1320"
        Height="800"
        MinWidth="1180"
        MinHeight="700"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp - Action Pad / Quick Copy / Item Actions" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Centralize Action Pads, Quick Copy shortcuts and per-item macros with the SAP visual language." Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <!-- Action Pad column -->
                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Action Pads" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBox Text="{Binding PadSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <ListBox ItemsSource="{Binding PadsView}"
                                         SelectedItem="{Binding SelectedPad}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Height="260">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FormType}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="New" Command="{Binding NewPadCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Duplicate" Command="{Binding DuplicatePadCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Delete" Command="{Binding DeletePadCommand}" Background="#FFB33939" />
                                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Pad Details" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Title" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedPad.Title, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedPad.FormType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Position" Style="{StaticResource LabelStyle}" />
                                <ComboBox SelectedItem="{Binding SelectedPad.Position, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="Right" />
                                    <ComboBoxItem Content="Left" />
                                </ComboBox>

                                <TextBlock Text="Buttons" Style="{StaticResource LabelStyle}" Margin="0,8,0,4" />
                                <ListBox ItemsSource="{Binding SelectedPad.Buttons}"
                                         SelectedItem="{Binding SelectedPadButton}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Height="220">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Label" Style="{StaticResource LabelStyle}" />
                                                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Text="Action" Style="{StaticResource LabelStyle}" />
                                                        <TextBox Text="{Binding Action, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                        <TextBlock Text="Order" Style="{StaticResource LabelStyle}" />
                                                        <TextBox Width="60" Text="{Binding Order, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel>
                                    <Button Content="Add Button" Command="{Binding AddPadButtonCommand}" />
                                    <Button Content="Remove Button" Command="{Binding DeletePadButtonCommand}" Background="#FFB33939" />
                                    <Button Content="Save Pad" Command="{Binding SavePadCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Quick Copy column -->
                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Quick Copy" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBox Text="{Binding QuickSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <ListBox ItemsSource="{Binding QuickView}"
                                         SelectedItem="{Binding SelectedQuickCopy}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Height="200">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding ButtonLabel}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SourceFormType}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="New" Command="{Binding NewQuickCopyCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Duplicate" Command="{Binding DuplicateQuickCopyCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Delete" Command="{Binding DeleteQuickCopyCommand}" Background="#FFB33939" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Quick Copy Details" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Button Label" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedQuickCopy.ButtonLabel, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Source Form Type" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedQuickCopy.SourceFormType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Source Object Type" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedQuickCopy.SourceObjectType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Target Object Type" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedQuickCopy.TargetObjectType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Post Macro" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedQuickCopy.PostMacro, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" />
                                <CheckBox Content="Active" IsChecked="{Binding SelectedQuickCopy.Active}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <WrapPanel>
                                    <Button Content="Save Quick Copy" Command="{Binding SaveQuickCopyCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Item Actions column -->
                    <StackPanel Grid.Column="4">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Item Actions" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBox Text="{Binding ItemSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <ListBox ItemsSource="{Binding ItemView}"
                                         SelectedItem="{Binding SelectedItemAction}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Height="200">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding FormType}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ItemId}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="New" Command="{Binding NewItemActionCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Duplicate" Command="{Binding DuplicateItemActionCommand}" Background="{DynamicResource AccentAltBrush}" />
                                    <Button Content="Delete" Command="{Binding DeleteItemActionCommand}" Background="#FFB33939" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Item Action Details" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedItemAction.FormType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Item ID" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedItemAction.ItemId, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Event" Style="{StaticResource LabelStyle}" />
                                <ComboBox Text="{Binding SelectedItemAction.Event, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="Click" />
                                    <ComboBoxItem Content="Change" />
                                    <ComboBoxItem Content="Choose" />
                                </ComboBox>
                                <TextBlock Text="Macro" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedItemAction.Action, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" />
                                <WrapPanel>
                                    <Button Content="Save Item Action" Command="{Binding SaveItemActionCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Close" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="..." FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
