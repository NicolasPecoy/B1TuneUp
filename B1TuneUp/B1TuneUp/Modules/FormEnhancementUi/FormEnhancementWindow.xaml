<Window x:Class="B1TuneUp.Modules.FormEnhancementUi.FormEnhancementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Estudio de Formularios"
        Width="1380"
        Height="820"
        MinWidth="1220"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp Estudio de Formularios" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Administra ajustes de formularios, valores por defecto y reglas de bloqueo en una sola interfaz estilo SAP." Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="24" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Configuraciones de formulario -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Configuraciones de formulario" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox Text="{Binding FormSettingsSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <ListBox ItemsSource="{Binding FormSettingsView}"
                                     SelectedItem="{Binding SelectedFormSetting}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     Height="260">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding FormType}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding UserCode}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Nuevo" Command="{Binding NewFormSettingCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding DuplicateFormSettingCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteFormSettingCommand}" Background="#FFB33939" />
                                <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Detalle de configuracion" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Tipo de formulario" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedFormSetting.FormType, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Usuario" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedFormSetting.UserCode, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Datos crudos (W=Ancho;H=Alto;CW_matriz_col=Ancho)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedFormSetting.Data, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="200" />
                            <WrapPanel>
                                <Button Content="Guardar" Command="{Binding SaveFormSettingCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Valores por defecto -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Valores por defecto" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox Text="{Binding DefaultValuesSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <ListBox ItemsSource="{Binding DefaultValuesView}"
                                     SelectedItem="{Binding SelectedDefaultValue}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     Height="240">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding FormType}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ItemId}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Nuevo" Command="{Binding NewDefaultValueCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding DuplicateDefaultValueCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteDefaultValueCommand}" Background="#FFB33939" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Detalle del valor por defecto" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Tipo de formulario" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedDefaultValue.FormType, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="ID del item" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedDefaultValue.ItemId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Columna (opcional)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedDefaultValue.ColumnId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Evento" Style="{StaticResource LabelStyle}" />
                            <ComboBox Text="{Binding SelectedDefaultValue.OnEvent, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="Carga" />
                                <ComboBoxItem Content="Cambio" />
                            </ComboBox>
                            <TextBlock Text="Consulta SQL / macro" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedDefaultValue.Query, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="140" FontFamily="Consolas" />
                            <WrapPanel>
                                <Button Content="Guardar" Command="{Binding SaveDefaultValueCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Reglas de bloqueo -->
                <StackPanel Grid.Column="4">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Reglas de bloqueo" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox Text="{Binding LockSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <ListBox ItemsSource="{Binding LockRulesView}"
                                     SelectedItem="{Binding SelectedLockRule}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     Height="240">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding FormType}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ItemId}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Nuevo" Command="{Binding NewLockRuleCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding DuplicateLockRuleCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteLockRuleCommand}" Background="#FFB33939" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Detalle de la regla de bloqueo" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Tipo de formulario" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedLockRule.FormType, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="ID del item" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedLockRule.ItemId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Columna (opcional)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedLockRule.ColumnId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Item disparador" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedLockRule.TriggerItem, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Evento" Style="{StaticResource LabelStyle}" />
                            <ComboBox Text="{Binding SelectedLockRule.OnEvent, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="Carga" />
                                <ComboBoxItem Content="Cambio" />
                            </ComboBox>
                            <TextBlock Text="Tipo de bloqueo" Style="{StaticResource LabelStyle}" />
                            <ComboBox Text="{Binding SelectedLockRule.LockType, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="SoloLectura" />
                                <ComboBoxItem Content="Oculto" />
                                <ComboBoxItem Content="Deshabilitado" />
                            </ComboBox>
                            <TextBlock Text="Condicion (SQL / IF)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedLockRule.Condition, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" FontFamily="Consolas" />
                            <WrapPanel>
                                <Button Content="Guardar" Command="{Binding SaveLockRuleCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cerrar" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="..." FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
