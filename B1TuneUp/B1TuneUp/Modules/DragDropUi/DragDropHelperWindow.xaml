<Window x:Class="B1TuneUp.Modules.DragDropUi.DragDropHelperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B1TuneUp - Drag &amp; Drop Helper"
        Width="420"
        Height="260"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B1TuneUp;component/Resources/B1Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="16"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <StackPanel>
            <TextBlock Text="Source Item ID" Style="{StaticResource LabelTextBlockStyle}" />
            <TextBox Text="{Binding SourceItemId, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Target Item ID" Style="{StaticResource LabelTextBlockStyle}" />
            <TextBox Text="{Binding TargetItemId, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Registrar Bind"
                    Width="160"
                    Command="{Binding BindCommand}" />
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
