<Window x:Class="B1TuneUp.Modules.EmailDesigner.EmailDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Email &amp; Notification Designer"
        Width="1240"
        Height="780"
        MinWidth="1100"
        MinHeight="700"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,24,24,28" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Email &amp; Notification Designer"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold" />
                <TextBlock Text="Diseña plantillas de email y notificaciones alineadas al estilo SAP Business One."
                           Foreground="#CCFFFFFF"
                           FontSize="14"
                           Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#CCFFFFFF"
                           FontSize="13"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Filtros" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                    <TextBlock Text="Buscar" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Canal" Style="{StaticResource LabelStyle}" />
                    <ComboBox ItemsSource="{Binding ChannelFilterOptions}"
                              SelectedItem="{Binding ChannelFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Content="Solo activos" IsChecked="{Binding OnlyActive}" Margin="0,0,0,12" />

                    <ListBox ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             DisplayMemberPath="DisplayName"
                             Height="420"
                             Margin="0,8,0,0"
                             Background="{DynamicResource SurfaceAltBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1" />

                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                        <Button Content="Nuevo" Command="{Binding NewCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Duplicar" Command="{Binding DuplicateCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Eliminar" Command="{Binding DeleteCommand}" Background="#FFB33939" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Código" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.Code}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                                <TextBlock Text="Canal" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding ChannelOptions}"
                                          SelectedItem="{Binding SelectedTemplate.Channel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Prioridad" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding PriorityOptions}"
                                          SelectedItem="{Binding SelectedTemplate.Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Activo" IsChecked="{Binding SelectedTemplate.Active}" Margin="0,4,0,12" />
                                <TextBlock Text="Última actualización" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.UpdatedAt, StringFormat=dd/MM/yyyy HH:mm}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Remitente" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.Sender, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Para" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.To, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Separar múltiples correos con ';' o '|'" />
                                <TextBlock Text="CC" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.Cc, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="BCC" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.Bcc, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Adjuntos (ruta separada por '|')" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.Attachment, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Notas de uso / Trigger" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedTemplate.Trigger, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="60" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Contenido" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                            <TextBlock Text="Asunto" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedTemplate.Subject, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Cuerpo (HTML/Texto)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedTemplate.Body, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="220"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>

                    <WrapPanel>
                        <Button Content="Guardar" Command="{Binding SaveCommand}" />
                        <Button Content="Enviar prueba" Command="{Binding SendTestCommand}" Background="{DynamicResource AccentAltBrush}" />
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <Button Content="Cerrar" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
              Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⟳" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
