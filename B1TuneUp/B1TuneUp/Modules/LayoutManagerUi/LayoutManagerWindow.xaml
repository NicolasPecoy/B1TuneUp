<Window x:Class="B1TuneUp.Modules.LayoutManagerUi.LayoutManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp · Layout Manager"
        Width="1200"
        Height="720"
        MinWidth="1000"
        MinHeight="620"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,12,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,16,0,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,24,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="220"
                             Margin="0"
                             Padding="8,4"
                             Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Buscar por formulario, nombre o descripción"
                             Background="White" />
                    <Button Content="Refrescar" Command="{Binding RefreshCommand}" Margin="12,0,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="B1TuneUp · Layout Manager"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0" />
                    <TextBlock Text="Gestiona layouts guardados en @BTUN_LAYOUT y aplica SRF de forma segura"
                               Foreground="#CCFFFFFF"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <DockPanel>
                    <DataGrid ItemsSource="{Binding LayoutsView}"
                              SelectedItem="{Binding SelectedLayout}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Form Type" Binding="{Binding FormType}" Width="*" />
                            <DataGridTextColumn Header="Layout" Binding="{Binding LayoutName}" Width="*" />
                            <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="1.5*" />
                            <DataGridTextColumn Header="Actualizado" Binding="{Binding UpdatedAt}" Width="0.8*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Grid.Column="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Acciones" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding SelectedLayout.DisplayName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedLayout.MetadataLine}" Margin="0,0,0,20" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Exportar SRF" Command="{Binding ExportCommand}" />
                            <Button Content="Aplicar en SAP" Command="{Binding ApplyCommand}" />
                            <Button Content="Eliminar" Command="{Binding DeleteCommand}" Background="#FFB33939" />
                        </StackPanel>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,20,0,20" />

                        <TextBlock Text="Importar nuevo layout" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                        <TextBlock Text="Tipo de formulario (manual)" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="200" Text="{Binding ManualFormType, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Detectar" Command="{Binding DetectActiveFormCommand}" />
                        </StackPanel>

                        <TextBlock Text="Nombre del layout" />
                        <TextBox Text="{Binding NewLayoutName, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Content="Importar archivo..." Command="{Binding ImportCommand}" />

                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,16,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    Padding="12"
                    CornerRadius="10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding BusyMessage}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,0" />
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <Button Content="Cerrar"
                        Width="140"
                        Background="{DynamicResource PrimaryDarkBrush}"
                        Click="OnCloseClick" />
            </StackPanel>
        </Grid>

        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#60000000">
            <Viewbox Width="120" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Procesando..." Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <ProgressBar IsIndeterminate="True" Width="120" Height="6" />
                </StackPanel>
            </Viewbox>
        </Grid>
    </Grid>
</Window>
