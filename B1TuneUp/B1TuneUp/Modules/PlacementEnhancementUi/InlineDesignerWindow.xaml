<Window x:Class="B1TuneUp.Modules.PlacementEnhancementUi.InlineDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#AA000000"
        Topmost="True"
        ShowInTaskbar="False"
        Width="1200"
        Height="820"
        PreviewKeyDown="OnPreviewKeyDown"
        MouseLeftButtonDown="OnWindowDrag">
    <Window.Resources>
        <Style x:Key="DesignerBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#22000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="#FF00D1FF"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <ControlTemplate x:Key="ResizeThumbTemplate" TargetType="Thumb">
            <Border Width="12"
                    Height="12"
                    CornerRadius="2"
                    BorderBrush="#222222"
                    BorderThickness="0.5"
                    Background="{TemplateBinding Background}"/>
        </ControlTemplate>
    </Window.Resources>
    <Border CornerRadius="12" BorderBrush="#44FFFFFF" BorderThickness="1" Padding="16" Background="#EE101820">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Editar con TuneUp" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding FormTitle}" Foreground="#CCFFFFFF" FontSize="13" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <ToggleButton Content="Snap Grid"
                                  IsChecked="{Binding SnapToGrid}"
                                  Width="90"
                                  Height="26"
                                  Margin="0,0,8,0"
                                  Foreground="White"
                                  Background="#552E75B6"
                                  BorderThickness="0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="Grid" Foreground="#CCFFFFFF" Margin="0,0,6,0"/>
                        <Slider Width="120"
                                Minimum="1"
                                Maximum="30"
                                Value="{Binding GridSize}"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"/>
                    </StackPanel>
                    <Button Content="Cerrar"
                            Width="80"
                            Height="28"
                            Background="#B33939"
                            Foreground="White"
                            BorderThickness="0"
                            Click="OnCloseClick"/>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0CFFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas Width="{Binding FormWidth}"
                                Height="{Binding FormHeight}"
                                Background="#11000000">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}" Height="{Binding Height}">
                                            <Border Style="{StaticResource DesignerBorderStyle}"
                                                    Background="#552E75B6"
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ItemId}" FontSize="10" Foreground="White" />
                                                    <TextBlock Text="{Binding Caption}" FontSize="12" Foreground="#FFEBEBEB" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                            <Thumb DragDelta="OnMoveThumbDragDelta"
                                                   DragStarted="OnDragStarted"
                                                   DragCompleted="OnDragCompleted"
                                                   Tag="{Binding}"
                                                   Background="#00000000"/>
                                            <Thumb Width="12"
                                                   Height="12"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Margin="0,0,2,2"
                                                   Cursor="SizeNWSE"
                                                   DragDelta="OnResizeThumbDragDelta"
                                                   DragStarted="OnDragStarted"
                                                   DragCompleted="OnDragCompleted"
                                                   Tag="{Binding}"
                                                   Template="{StaticResource ResizeThumbTemplate}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1" Margin="16,0,0,0" Background="#16222E" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Detalle" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding FormType}" Foreground="#CCFFFFFF" Margin="0,2,0,12"/>
                        <StackPanel>
                            <TextBlock Text="Item seleccionado" Foreground="#CCFFFFFF"/>
                            <TextBlock Text="{Binding SelectedItem.ItemId}" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedItem.Caption}" Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,8"/>
                        </StackPanel>
                        <UniformGrid Columns="2" Rows="2" Margin="0,8,0,8">
                            <Button Content="Aplicar"
                                    Command="{Binding ApplyCommand}"
                                    Margin="0,4,8,0"/>
                            <Button Content="Guardar Layout"
                                    Command="{Binding PersistCommand}"
                                    Margin="0,4,0,0"/>
                            <Button Content="Validaciones"
                                    Command="{Binding OpenValidationCommand}"
                                    Margin="0,4,8,0"/>
                            <Button Content="Acciones"
                                    Command="{Binding OpenActionCommand}"
                                    Margin="0,4,0,0"/>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Exportar"
                                    Command="{Binding ExportCommand}"
                                    Background="#2E75B6"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Margin="0,0,8,0"/>
                            <Button Content="Importar"
                                    Command="{Binding ImportCommand}"
                                    Background="#F39C12"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" Margin="0,20,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
