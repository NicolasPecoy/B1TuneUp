<Window x:Class="B1TuneUp.Modules.AuditLogViewer.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Log Viewer"
        Width="1180"
        Height="720"
        MinWidth="1000"
        MinHeight="640"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,24,24,28" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Log Viewer" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Explora y filtra el historial completo de acciones del add-on."
                           Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Filtros" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Desde" Style="{StaticResource LabelStyle}" />
                    <DatePicker SelectedDate="{Binding FromDate}" />
                    <TextBlock Text="Hasta" Style="{StaticResource LabelStyle}" />
                    <DatePicker SelectedDate="{Binding ToDate}" />
                    <TextBlock Text="Tipo" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding TypeFilter, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Estado" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding StatusFilter, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Usuario" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding UserFilter, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Buscar texto" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Aplicar filtros" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="150" />
                    </Grid.RowDefinitions>

                    <DataGrid ItemsSource="{Binding Entries}"
                              SelectedItem="{Binding SelectedEntry}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Margin="0,0,0,16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="DocEntry" Binding="{Binding DocEntry}" Width="80" />
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Date, StringFormat=G}" Width="150" />
                            <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="120" />
                            <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="Usuario" Binding="{Binding User}" Width="120" />
                            <DataGridTextColumn Header="Detalles" Binding="{Binding Details}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Detalles seleccionados" Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding SelectedEntry.Details}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                        <WrapPanel>
                            <Button Content="Copiar detalles" Command="{Binding CopyDetailsCommand}" Background="{DynamicResource AccentAltBrush}" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cerrar" Width="120" Background="{DynamicResource PrimaryDarkBrush}" Click="OnCloseClick" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⌛" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
