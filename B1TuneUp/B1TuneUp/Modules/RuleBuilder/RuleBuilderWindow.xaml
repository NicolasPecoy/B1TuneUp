<Window x:Class="B1TuneUp.Modules.RuleBuilder.RuleBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Rule Builder"
        Width="1220"
        Height="760"
        MinWidth="1080"
        MinHeight="680"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="RuleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding FormType}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding EventType}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,24,24,28" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Rule Builder" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Administra reglas del MacroEngine (condiciones/acciones) con una experiencia visual uniforme."
                           Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Filtros" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                    <ComboBox ItemsSource="{Binding FormTypes}" Text="{Binding FormFilter, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" />
                    <TextBlock Text="Tipo" Style="{StaticResource LabelStyle}" />
                    <ComboBox ItemsSource="{Binding RuleTypeOptions}" SelectedItem="{Binding TypeFilter, Mode=TwoWay}" />
                    <TextBlock Text="Buscar" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}" />

                    <ListBox ItemsSource="{Binding FilteredRules}"
                             SelectedItem="{Binding SelectedRule}"
                             ItemTemplate="{StaticResource RuleTemplate}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Background="{DynamicResource SurfaceAltBrush}"
                             Height="420" />

                    <UniformGrid Rows="2" Columns="2" Margin="0,16,0,0">
                        <Button Content="Nueva" Command="{Binding NewCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Duplicar" Command="{Binding DuplicateCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Eliminar" Command="{Binding DeleteCommand}" Background="#FFB33939" />
                        <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedRule.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedRule.FormType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Evento" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding EventSuggestions}"
                                          Text="{Binding SelectedRule.EventType, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Tipo" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding RuleTypeOptions}"
                                          SelectedItem="{Binding SelectedRule.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="BeforeAction" IsChecked="{Binding SelectedRule.BeforeAction}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Condición (SQL)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedRule.Condition, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" TextWrapping="Wrap" />
                            <WrapPanel>
                                <Button Content="Probar condición" Command="{Binding TestConditionCommand}" Background="{DynamicResource AccentAltBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Acción (Macro)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedRule.Action, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="160" TextWrapping="Wrap" />
                            <WrapPanel>
                                <Button Content="Ejecutar macro" Command="{Binding RunActionCommand}" Background="{DynamicResource PrimaryBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <WrapPanel>
                            <Button Content="Guardar" Command="{Binding SaveCommand}" />
                        </WrapPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cerrar" Width="120" Background="{DynamicResource PrimaryDarkBrush}" Click="OnCloseClick" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⌛" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
