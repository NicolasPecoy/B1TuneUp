<Window x:Class="B1TuneUp.Modules.UiDesigner.UiCustomizerWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        mc:Ignorable="d"

        Title="B1TuneUp UI Customizer"

        Width="1220"

        Height="760"

        MinWidth="1100"

        MinHeight="680"

        Background="{DynamicResource WindowBackgroundBrush}"

        WindowStartupLocation="CenterScreen"

        Topmost="True"

        ShowInTaskbar="False">

    <Window.Resources>

        <Color x:Key="PrimaryColor">#1F4E79</Color>

        <Color x:Key="PrimaryDarkColor">#0F263D</Color>

        <Color x:Key="AccentColor">#F39C12</Color>

        <Color x:Key="AccentAltColor">#2E75B6</Color>

        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>

        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>

        <Color x:Key="BorderColor">#D7DCE3</Color>

        <Color x:Key="TextPrimaryColor">#10263C</Color>

        <Color x:Key="TextSecondaryColor">#516173</Color>



        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />

        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />

        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />

        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />

        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />

        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />

        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />

        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />



        <Style TargetType="TextBlock" x:Key="LabelStyle">

            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />

            <Setter Property="FontSize" Value="13" />

            <Setter Property="FontWeight" Value="SemiBold" />

            <Setter Property="Margin" Value="0,0,0,4" />

        </Style>



        <Style TargetType="TextBox">

            <Setter Property="Padding" Value="8,4" />

            <Setter Property="Margin" Value="0,0,0,12" />

            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />

            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />

            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />

        </Style>



        <Style TargetType="ComboBox">

            <Setter Property="Padding" Value="8,4" />

            <Setter Property="Margin" Value="0,0,0,12" />

            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />

            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />

            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />

        </Style>



        <Style TargetType="Button">

            <Setter Property="Padding" Value="12,6" />

            <Setter Property="Margin" Value="0,8,8,0" />

            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />

            <Setter Property="Foreground" Value="White" />

            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="FontWeight" Value="SemiBold" />

            <Setter Property="Cursor" Value="Hand" />

        </Style>



        <Style TargetType="Border" x:Key="CardStyle">

            <Setter Property="CornerRadius" Value="12" />

            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />

            <Setter Property="Padding" Value="16" />

            <Setter Property="Margin" Value="0,0,0,20" />

            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />

            <Setter Property="BorderThickness" Value="1" />

        </Style>



        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />



        <DataTemplate x:Key="EntryTemplate">

            <StackPanel>

                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

                <TextBlock Text="{Binding Action}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />

            </StackPanel>

        </DataTemplate>

    </Window.Resources>



    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,24,24,28" CornerRadius="0,0,24,24">

            <StackPanel>

                <TextBlock Text="B1TuneUp UI Customizer" Foreground="White" FontSize="26" FontWeight="Bold" />

                <TextBlock Text="Administra movimientos, ocultamientos y botones personalizados de formularios SAP Business One."

                           Foreground="#CCFFFFFF" Margin="0,6,0,0" FontSize="14" />

                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />

            </StackPanel>

        </Border>



        <TabControl Grid.Row="1" Margin="24">
            <TabItem Header="UI Customizer">
                <Grid>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="320" />

                <ColumnDefinition Width="24" />

                <ColumnDefinition Width="*" />

            </Grid.ColumnDefinitions>



            <Border Style="{StaticResource CardStyle}">

                <StackPanel>

                    <TextBlock Text="Filtros" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />

                    <ComboBox ItemsSource="{Binding FormTypes}" Text="{Binding FormFilter, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" />

                    <TextBlock Text="Buscar Item / Acción" Style="{StaticResource LabelStyle}" />

                    <TextBox Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}" />



                    <ListBox ItemsSource="{Binding FilteredEntries}"

                             SelectedItem="{Binding SelectedEntry}"

                             ItemTemplate="{StaticResource EntryTemplate}"

                             Margin="0,8,0,0"

                             Height="420"

                             BorderBrush="{DynamicResource BorderBrush}"

                             BorderThickness="1"

                             Background="{DynamicResource SurfaceAltBrush}" />



                    <UniformGrid Rows="2" Columns="2" Margin="0,16,0,0">

                        <Button Content="Nueva" Command="{Binding NewCommand}" Background="{DynamicResource AccentAltBrush}" />

                        <Button Content="Duplicar" Command="{Binding DuplicateCommand}" Background="{DynamicResource AccentAltBrush}" />

                        <Button Content="Eliminar" Command="{Binding DeleteCommand}" Background="#FFB33939" />

                        <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />

                    </UniformGrid>

                </StackPanel>

            </Border>



            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <Border Style="{StaticResource CardStyle}">

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>

                                <RowDefinition Height="Auto" />

                                <RowDefinition Height="Auto" />

                                <RowDefinition Height="Auto" />

                            </Grid.RowDefinitions>



                            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                                <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.FormType, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Item ID" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.ItemId, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Nombre interno" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.Name, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>



                            <StackPanel Grid.Column="1">

                                <TextBlock Text="Acción" Style="{StaticResource LabelStyle}" />

                                <ComboBox ItemsSource="{Binding ActionOptions}"

                                          SelectedItem="{Binding SelectedEntry.Action, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Texto / Etiqueta" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.Label, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>

                        </Grid>

                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Condición SQL (se evalúa antes de aplicar)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedEntry.Condition, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     Height="80"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Usuario (lista separada por comas)" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedEntry.UserCode, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Grupo de usuario" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedEntry.UserGroup, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Dependencias (códigos o feature:*)" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedEntry.DependsOn, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Localización (es-AR, CL, etc.)" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedEntry.Localization, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Variante / Bundle" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedEntry.Variant, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Hereda de código" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedEntry.InheritFrom, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Prioridad" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedEntry.Priority, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>



                            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                                <TextBlock Text="Left" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.Left, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                                <TextBlock Text="Top" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.Top, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            </StackPanel>



                            <StackPanel Grid.Column="1">

                                <TextBlock Text="Width" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.Width, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                                <TextBlock Text="Height" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.Height, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            </StackPanel>

                        </Grid>

                    </Border>



                    <Border Style="{StaticResource CardStyle}">

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>



                            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                                <TextBlock Text="From Pane" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.FromPane, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            </StackPanel>



                            <StackPanel Grid.Column="1">

                                <TextBlock Text="To Pane" Style="{StaticResource LabelStyle}" />

                                <TextBox Text="{Binding SelectedEntry.ToPane, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                                <TextBlock Text="Ãltima actualizaciÃ³n" Style="{StaticResource LabelStyle}" />

                                <TextBlock Text="{Binding SelectedEntry.UpdatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Foreground="{DynamicResource TextPrimaryBrush}" />

                            </StackPanel>

                        </Grid>

                    </Border>



                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <WrapPanel>

                                <Button Content="Guardar" Command="{Binding SaveCommand}" />

                                <Button Content="Refrescar Formulario (aplicar)" Command="{Binding RefreshActiveFormCommand}" Background="{DynamicResource AccentAltBrush}" />

                                <Button Content="Abrir Item Placement" Command="{Binding LaunchPlacementCommand}" Background="{DynamicResource PrimaryBrush}" />

                            </WrapPanel>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </ScrollViewer>

        
                </Grid>
            </TabItem>
            <TabItem Header="Action Pad Designer">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Action Pads" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox Text="{Binding PadSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <ListBox ItemsSource="{Binding PadsView}"
                                     SelectedItem="{Binding SelectedPad}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     Height="420">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding FormType}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <UniformGrid Rows="2" Columns="2" Margin="0,16,0,0">
                                <Button Content="Nuevo" Command="{Binding PadNewCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding PadDuplicateCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding PadDeleteCommand}" Background="#FFB33939" />
                                <Button Content="Actualizar" Command="{Binding PadRefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPad.FormType, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Título" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPad.Title, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Posición" Style="{StaticResource LabelStyle}" />
                                    <ComboBox SelectedValue="{Binding SelectedPad.Position, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content">
                                        <ComboBoxItem Content="Right" />
                                        <ComboBoxItem Content="Left" />
                                    </ComboBox>
                                    <TextBlock Text="Dock Mode" Style="{StaticResource LabelStyle}" />
                                    <ComboBox SelectedValue="{Binding SelectedPad.DockMode, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" IsEditable="True">
                                        <ComboBoxItem Content="Floating" />
                                        <ComboBoxItem Content="StickToForm" />
                                        <ComboBoxItem Content="Modal" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Columnas" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPad.Columns, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Ancho botón" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPad.ButtonWidth, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Alto botón" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPad.ButtonHeight, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Seguir formulario" IsChecked="{Binding SelectedPad.FollowForm, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Botones" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                    <ListBox ItemsSource="{Binding SelectedPad.Buttons}"
                                             SelectedItem="{Binding SelectedPadButton}"
                                             BorderBrush="{DynamicResource BorderBrush}"
                                             BorderThickness="1"
                                             Background="{DynamicResource SurfaceAltBrush}"
                                             Height="260">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4">
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Tooltip}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Content="Agregar" Command="{Binding PadAddButtonCommand}" Background="{DynamicResource AccentAltBrush}" />
                                        <Button Content="Duplicar" Command="{Binding PadDuplicateButtonCommand}" Background="{DynamicResource AccentAltBrush}" />
                                        <Button Content="Eliminar" Command="{Binding PadRemoveButtonCommand}" Background="#FFB33939" />
                                    </WrapPanel>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="Arriba" Command="{Binding PadMoveButtonUpCommand}" Background="{DynamicResource PrimaryBrush}" />
                                        <Button Content="Abajo" Command="{Binding PadMoveButtonDownCommand}" Background="{DynamicResource PrimaryBrush}" />
                                    </WrapPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Detalle del botón" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                    <TextBlock Text="Etiqueta" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPadButton.Label, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Tooltip" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPadButton.Tooltip, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Acción" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedPadButton.Action, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" FontFamily="Consolas" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Color (#RRGGBB)" Style="{StaticResource LabelStyle}" />
                                            <TextBox Text="{Binding SelectedPadButton.Color, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="HotKey" Style="{StaticResource LabelStyle}" />
                                            <TextBox Text="{Binding SelectedPadButton.HotKey, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Grid Row" Style="{StaticResource LabelStyle}" />
                                            <TextBox Text="{Binding SelectedPadButton.GridRow, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Grid Col" Style="{StaticResource LabelStyle}" />
                                            <TextBox Text="{Binding SelectedPadButton.GridCol, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Span (Cols/Rows)" Style="{StaticResource LabelStyle}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox Width="60" Margin="0,0,8,0" Text="{Binding SelectedPadButton.ColSpan, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Width="60" Text="{Binding SelectedPadButton.RowSpan, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Vista previa" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <ItemsControl ItemsSource="{Binding SelectedPad.Buttons}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Label}"
                                                    Margin="4"
                                                    Width="{Binding DataContext.SelectedPad.ButtonWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Height="{Binding DataContext.SelectedPad.ButtonHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Background="{Binding Color, TargetNullValue=#2E75B6}"
                                                    ToolTip="{Binding Tooltip}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <WrapPanel Margin="0,16,0,0" HorizontalAlignment="Right">
                                    <Button Content="Guardar Action Pad" Command="{Binding PadSaveCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </TabItem>
        </TabControl>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">

            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />

            <Button Content="Cerrar" Width="120" Background="{DynamicResource PrimaryDarkBrush}" Click="OnCloseClick" />

        </StackPanel>



        <Grid Background="#80000000"

              Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"

              Grid.RowSpan="3">

            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">

                <StackPanel HorizontalAlignment="Center">

                    <TextBlock Text="..." FontSize="32" HorizontalAlignment="Center" />

                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>

