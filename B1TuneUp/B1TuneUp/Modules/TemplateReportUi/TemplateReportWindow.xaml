<Window x:Class="B1TuneUp.Modules.TemplateReportUi.TemplateReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Template Studio"
        Width="1260"
        Height="800"
        MinWidth="1120"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,24,24,28" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Template &amp; Report Studio"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold" />
                <TextBlock Text="Administra templates de formularios y layouts/Crystal Reports con un estilo coherente a SAP Business One."
                           Foreground="#CCFFFFFF"
                           FontSize="14"
                           Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#CCFFFFFF"
                           FontSize="13"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="24" Background="Transparent" BorderThickness="0">
            <TabItem Header="Templates de Formularios" Padding="16,8">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Filtros" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                            <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding FormTypeFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Filtrar por tipo de formulario (ej. 139, SBOForm, etc.)" />
                            <TextBlock Text="Buscar por nombre o descripción" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding FormSearch, UpdateSourceTrigger=PropertyChanged}" />

                            <ListBox ItemsSource="{Binding FormTemplates}"
                                     SelectedItem="{Binding SelectedFormTemplate}"
                                     DisplayMemberPath="Name"
                                     Height="420"
                                     Margin="0,8,0,0"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1" />

                            <WrapPanel Margin="0,16,0,0">
                                <Button Content="Actualizar" Command="{Binding RefreshFormTemplatesCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                                <Button Content="Nuevo" Command="{Binding NewFormTemplateCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding DuplicateFormTemplateCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteFormTemplateCommand}" Background="#FFB33939" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedFormTemplate.Name, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedFormTemplate.Description, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Form Type" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedFormTemplate.FormType, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Creado por" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedFormTemplate.CreatedBy}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                                        <TextBlock Text="Creado" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedFormTemplate.CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                                        <TextBlock Text="Actualizado" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedFormTemplate.UpdatedAt, StringFormat=dd/MM/yyyy HH:mm}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Datos serializados" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedFormTemplate.SerializedData, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             Height="180"
                                             TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <Button Content="Copiar" Command="{Binding CopyTemplateDataCommand}" Background="{DynamicResource AccentAltBrush}" />
                                        <Button Content="Pegar" Command="{Binding PasteTemplateDataCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <WrapPanel>
                                <Button Content="Guardar Template" Command="{Binding SaveFormTemplateCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Report Templates" Padding="16,8">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Buscar" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding ReportSearch, UpdateSourceTrigger=PropertyChanged}" />

                            <ListBox ItemsSource="{Binding ReportTemplates}"
                                     SelectedItem="{Binding SelectedReportTemplate}"
                                     DisplayMemberPath="Name"
                                     Height="420"
                                     Margin="0,8,0,0"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1" />

                            <WrapPanel Margin="0,16,0,0">
                                <Button Content="Actualizar" Command="{Binding RefreshReportTemplatesCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                                <Button Content="Nuevo" Command="{Binding NewReportTemplateCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding DuplicateReportTemplateCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteReportTemplateCommand}" Background="#FFB33939" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedReportTemplate.Name, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedReportTemplate.Description, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Creado" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedReportTemplate.CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                                        <TextBlock Text="Actualizado" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding SelectedReportTemplate.UpdatedAt, StringFormat=dd/MM/yyyy HH:mm}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Parámetros (key=value|...)" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedReportTemplate.Parameters, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             Height="80"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Contenido Base64" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedReportTemplate.DataBase64, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             Height="220"
                                             TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <Button Content="Importar archivo" Command="{Binding ImportReportFileCommand}" Background="{DynamicResource AccentAltBrush}" />
                                        <Button Content="Exportar archivo" Command="{Binding ExportReportFileCommand}" Background="{DynamicResource PrimaryBrush}" />
                                        <Button Content="Copiar Base64" Command="{Binding CopyReportDataCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <WrapPanel>
                                <Button Content="Guardar Report Template" Command="{Binding SaveReportTemplateCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <Button Content="Refrescar Todo" Command="{Binding RefreshAllCommand}" Background="{DynamicResource PrimaryBrush}" />
            <Button Content="Cerrar" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
              Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⟳" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
