<Window x:Class="B1TuneUp.Modules.IntegrationUi.IntegrationConfiguratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Integration Configurator"
        Width="1180"
        Height="720"
        MinHeight="640"
        MinWidth="1080"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#f0f4f7</Color>
        <Color x:Key="BorderColor">#d7dce3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#e9edf3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,24,24,28" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Integration Manager" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Configura integraciones REST/SOAP con el mismo lenguaje visual de SAP Business One."
                           Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Integraciones" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding Integrations}"
                             SelectedItem="{Binding SelectedIntegration}"
                             DisplayMemberPath="DisplayName"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Background="{DynamicResource SurfaceAltBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Height="420" />
                    <UniformGrid Rows="2" Columns="2" Margin="0,16,0,0" HorizontalAlignment="Stretch">
                        <Button Content="Nueva" Command="{Binding NewCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Duplicar" Command="{Binding DuplicateCommand}" Background="{DynamicResource AccentAltBrush}" />
                        <Button Content="Eliminar" Command="{Binding DeleteCommand}" Background="#FFB33939" />
                        <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Grid.ColumnSpan="2">
                                    <TextBlock Text="Nombre de la integración" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedIntegration.Name, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,16,0">
                                    <TextBlock Text="Canal" Style="{StaticResource LabelStyle}" />
                                    <ComboBox ItemsSource="{Binding ChannelOptions}"
                                              SelectedItem="{Binding SelectedIntegration.Channel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="Verbo HTTP / Acción SOAP" Style="{StaticResource LabelStyle}" />
                                    <ComboBox ItemsSource="{Binding HttpMethodOptions}"
                                              Text="{Binding SelectedIntegration.Method, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                    <TextBlock Text="Endpoint" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedIntegration.Endpoint, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Integración activa"
                                      IsChecked="{Binding SelectedIntegration.Active}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Modo de autenticación" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding AuthModes}"
                                          SelectedItem="{Binding SelectedIntegration.AuthMode, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Usuario / Header" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedIntegration.AuthUser, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Para API Key ingresa el nombre del header (ej. X-API-Key)" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Password / Token / Clave" Style="{StaticResource LabelStyle}" />
                                <PasswordBox x:Name="SecretBox"
                                             PasswordChanged="OnSecretChanged" />
                                <TextBlock Text="Notas" Style="{StaticResource LabelStyle}" Margin="0,16,0,0" />
                                <TextBox Text="{Binding SelectedIntegration.Notes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="60" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Headers (uno por línea o '|')" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedIntegration.Headers, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="100" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Body / Payload (JSON o XML)" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SelectedIntegration.Body, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="100" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Intervalo (minutos) para monitoreo" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedIntegration.ScheduleMinutes, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Text="Macro manejador (cuando cambie la data)" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedIntegration.HandlerMacro, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Resultado de pruebas" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding SelectedIntegration.LastTestResult}" Height="120" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                                </StackPanel>
                            </Grid>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Guardar" Command="{Binding SaveCommand}" />
                                <Button Content="Probar conexión" Command="{Binding TestCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Iniciar Real-time" Command="{Binding StartRealtimeCommand}" Background="{DynamicResource PrimaryBrush}" />
                                <Button Content="Detener Real-time" Command="{Binding StopRealtimeCommand}" Background="#FFB33939" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cerrar" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⌛" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
