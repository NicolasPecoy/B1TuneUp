<Window x:Class="B1TuneUp.Modules.AutomationDashboardUi.AutomationDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="B1TuneUp Automation Dashboard"
        Width="1460"
        Height="820"
        MinWidth="1280"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="PrimaryDarkColor">#0F263D</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="AccentAltColor">#2E75B6</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource AccentAltColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp Automation Dashboard" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Supervisa menus, macros y despliegues desde una sola consola visual." Foreground="#CCFFFFFF" FontSize="14" Margin="0,6,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="24" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.6*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Menus personalizados -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Menus personalizados" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox Text="{Binding MenuSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <ListBox ItemsSource="{Binding MenusView}"
                                     SelectedItem="{Binding SelectedMenu}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     Height="260">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding MenuId}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Caption}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Nuevo" Command="{Binding NewMenuCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding DuplicateMenuCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteMenuCommand}" Background="#FFB33939" />
                                <Button Content="Actualizar" Command="{Binding RefreshCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Detalle del menu" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Parent ID" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMenu.ParentId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Menu ID" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMenu.MenuId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Titulo" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMenu.Caption, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Posicion" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMenu.Position, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Accion (macro a ejecutar)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMenu.Action, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="140" FontFamily="Consolas" />
                            <WrapPanel>
                                <Button Content="Guardar menu" Command="{Binding SaveMenuCommand}" />
                                <Button Content="Probar accion" Command="{Binding TestMenuCommand}" Background="{DynamicResource AccentAltBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Macros -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Macros registradas" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox Text="{Binding MacroSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <ListBox ItemsSource="{Binding MacrosView}"
                                     SelectedItem="{Binding SelectedMacro}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Background="{DynamicResource SurfaceAltBrush}"
                                     Height="240">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Nueva" Command="{Binding NewMacroCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Duplicar" Command="{Binding DuplicateMacroCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Eliminar" Command="{Binding DeleteMacroCommand}" Background="#FFB33939" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Detalle de macro" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Nombre" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMacro.Name, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Descripcion" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMacro.Description, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Codigo" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMacro.Code}" IsReadOnly="True" Background="{DynamicResource SurfaceAltBrush}" />
                            <TextBlock Text="Parametros" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMacro.Parameters, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Fuente" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding SelectedMacro.Source, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="140" FontFamily="Consolas" />
                            <WrapPanel>
                                <Button Content="Guardar macro" Command="{Binding SaveMacroCommand}" />
                                <Button Content="Ejecutar" Command="{Binding RunMacroCommand}" Background="{DynamicResource AccentAltBrush}" />
                                <Button Content="Copiar" Command="{Binding CopyMacroCommand}" Background="{DynamicResource PrimaryDarkBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Despliegues y estado -->
                <StackPanel Grid.Column="4">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Panel de despliegue" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Destino" Style="{StaticResource LabelStyle}" />
                            <ComboBox Text="{Binding DeployTarget, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="QA" />
                                <ComboBoxItem Content="PRD" />
                                <ComboBoxItem Content="DEV" />
                            </ComboBox>
                            <TextBlock Text="Notas" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding DeployNotes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="100" />
                            <Button Content="Simular despliegue" Command="{Binding DeployCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Resultado de pruebas" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="{Binding TestOutput}" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Height="200" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,16">
            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cerrar" Click="OnCloseClick" Background="{DynamicResource PrimaryDarkBrush}" />
        </StackPanel>

        <Grid Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="3">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="..." FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
