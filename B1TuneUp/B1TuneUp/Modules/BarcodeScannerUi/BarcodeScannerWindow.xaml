<Window x:Class="B1TuneUp.Modules.BarcodeScannerUi.BarcodeScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B1TuneUp · Barcode Scanner"
        Width="480"
        Height="489"
        MinWidth="420"
        MinHeight="260"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B1TuneUp;component/B1TuneUp/Resources/B1Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelTextBlockStyle}">
                <Setter Property="Margin" Value="0,12,0,4" />
            </Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource B1TextBoxStyle}" />
            <Style TargetType="Button" BasedOn="{StaticResource B1PrimaryButtonStyle}">
                <Setter Property="Width" Value="200" />
            </Style>
            <Style TargetType="Border" BasedOn="{StaticResource B1CardBorderStyle}">
                <Setter Property="Padding" Value="20" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="0,0,0,-10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Barcode Scanner"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold" />
                <TextBlock Text="Transfiere lecturas de código de barras al formulario activo."
                           Foreground="#CCFFFFFF"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="24,24,24,20">
            <StackPanel>
                <TextBlock Text="Target Item ID" />
                <TextBox Text="{Binding TargetItemId, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Valor escaneado" />
                <TextBox Text="{Binding ScannedValue, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Insertar en SAP"
                        Command="{Binding InjectCommand}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24,0,24,24">
            <Button Content="Cerrar"
                    Width="140"
                    Background="{DynamicResource PrimaryDarkBrush}"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>


