<Window x:Class="B1TuneUp.Modules.ConfigCenter.ConfigCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B1TuneUp Config Center"
        Width="1280"
        Height="820"
        MinWidth="1160"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Color x:Key="PrimaryColor">#1F4E79</Color>
        <Color x:Key="AccentColor">#F39C12</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SurfaceAltColor">#F4F6F9</Color>
        <Color x:Key="BorderColor">#D7DCE3</Color>
        <Color x:Key="TextPrimaryColor">#10263C</Color>
        <Color x:Key="TextSecondaryColor">#516173</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E9EDF3" />

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Border" x:Key="PanelStyle">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24,22,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp Config Center" Foreground="White" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CCFFFFFF" FontSize="13" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="24">
            <TabItem Header="Modules / Diagnostics">
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                                <Button Content="Save Modules" Command="{Binding SaveModulesCommand}" />
                                <Button Content="Repair Metadata" Command="{Binding RepairMetadataCommand}" />
                                <Button Content="Export" Command="{Binding ExportCommand}" />
                                <Button Content="Preview Import" Command="{Binding PreviewImportCommand}" />
                                <Button Content="Import" Command="{Binding ImportCommand}" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Modules}"
                                      SelectedItem="{Binding SelectedModule}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="48" />
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="110" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="190" />
                                    <DataGridTextColumn Header="Allowed Users" Binding="{Binding AllowedUsers}" Width="150" />
                                    <DataGridTextColumn Header="Allowed Groups" Binding="{Binding AllowedGroups}" Width="150" />
                                    <DataGridTextColumn Header="Denied Users" Binding="{Binding DeniedUsers}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Diagnostics" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                            <DataGrid ItemsSource="{Binding Diagnostics}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="110" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="190" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock DockPanel.Dock="Bottom" Text="Import Preview" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,8" />
                            <DataGrid DockPanel.Dock="Bottom"
                                      ItemsSource="{Binding PackagePreview}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      Height="170">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="120" />
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="160" />
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="90" />
                                    <DataGridCheckBoxColumn Header="Conflict" Binding="{Binding Conflict}" Width="70" />
                                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Metadata">
                <Border Margin="0,14,0,0" Style="{StaticResource PanelStyle}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                            <Button Content="Repair Schema" Command="{Binding RepairMetadataCommand}" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Metadata}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Margin="0,12,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Object" Binding="{Binding DisplayName}" Width="210" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                <DataGridCheckBoxColumn Header="Table" Binding="{Binding IsTable}" Width="65" IsReadOnly="True" />
                                <DataGridTextColumn Header="Description" Binding="{Binding FieldDescription}" Width="*" />
                                <DataGridTextColumn Header="Table Desc" Binding="{Binding TableDescription}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="Universal Functions">
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="440" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <Button Content="New" Command="{Binding NewFunctionCommand}" />
                                <Button Content="Save" Command="{Binding SaveFunctionCommand}" />
                                <Button Content="Delete" Command="{Binding DeleteFunctionCommand}" />
                                <Button Content="Test" Command="{Binding TestFunctionCommand}" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Functions}" SelectedItem="{Binding SelectedFunction}" DisplayMemberPath="Code" Margin="0,12,0,0" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                        <Grid DataContext="{Binding SelectedFunction}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Code" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Name" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Type" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding DataContext.FunctionTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Type}" />
                                <CheckBox Content="Active" IsChecked="{Binding Active}" Margin="0,4,0,12" />
                                <TextBlock Text="Parameters" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Parameters, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="90" />
                                <TextBlock Text="Condition SQL" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="70" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Payload" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Payload, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="220" FontFamily="Consolas" />
                                <TextBlock Text="Allowed Users" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding AllowedUsers, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Allowed Groups" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding AllowedGroups, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Denied Users" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding DeniedUsers, UpdateSourceTrigger=PropertyChanged}" />
                                <UniformGrid Columns="4" Margin="0,0,0,8">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Result Var" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding ResultVariable, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="On Success" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding OnSuccessFunction, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="On Error" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding OnErrorFunction, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Retry" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </UniformGrid>
                                <CheckBox Content="Continue on error" IsChecked="{Binding ContinueOnError}" Margin="0,0,0,8" />
                                <TextBlock Text="Notes" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="70" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Event Triggers">
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="430" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <Button Content="New" Command="{Binding NewTriggerCommand}" />
                                <Button Content="Save" Command="{Binding SaveTriggerCommand}" />
                                <Button Content="Delete" Command="{Binding DeleteTriggerCommand}" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Triggers}" SelectedItem="{Binding SelectedTrigger}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="On" Binding="{Binding Active}" Width="45" />
                                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="140" />
                                    <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="140" />
                                    <DataGridTextColumn Header="Form" Binding="{Binding FormType}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                        <Grid DataContext="{Binding SelectedTrigger}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Code" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Name" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Event" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding DataContext.TriggerEvents, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding EventType}" />
                                <TextBlock Text="Form / Item / Column" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding FormType, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Text="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Text="{Binding ColumnId, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Before action" IsChecked="{Binding BeforeAction}" Margin="0,4,0,8" />
                                <CheckBox Content="Trace enabled" IsChecked="{Binding TraceEnabled}" Margin="0,0,0,8" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Condition SQL" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="90" FontFamily="Consolas" />
                                <TextBlock Text="Universal Function Code" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding UniversalFunctionCode, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Fallback Macro" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Macro, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" FontFamily="Consolas" />
                                <TextBlock Text="Allowed / Denied Users" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding AllowedUsers, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Text="{Binding DeniedUsers, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Allowed / Denied Groups" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding AllowedGroups, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Text="{Binding DeniedGroups, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Authorization">
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <Button Content="New Group" Command="{Binding NewGroupCommand}" />
                                <Button Content="Save" Command="{Binding SaveGroupCommand}" />
                                <Button Content="Delete" Command="{Binding DeleteGroupCommand}" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" DisplayMemberPath="Code" Margin="0,12,0,0" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Super Users" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding SuperUsers, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save Super Users" Command="{Binding SaveSuperUsersCommand}" />
                                    <Button Content="Simulate" Command="{Binding SimulateAuthorizationCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding SimulationResult}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,8" />
                            </StackPanel>
                            <Grid Grid.Row="2" DataContext="{Binding SelectedGroup}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Group Code" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Name" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="SAP Users" Style="{StaticResource LabelStyle}" />
                                    <DataGrid ItemsSource="{Binding DataContext.SapUsers, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding DataContext.SelectedSapUser, RelativeSource={RelativeSource AncestorType=Window}}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              Height="120"
                                              Margin="0,0,0,10">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Code" Binding="{Binding UserCode}" Width="110" />
                                            <DataGridTextColumn Header="Name" Binding="{Binding UserName}" Width="*" />
                                            <DataGridCheckBoxColumn Header="Super" Binding="{Binding SuperUser}" Width="70" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="Users" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding Users, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="140" />
                                    <TextBlock Text="Notes" Style="{StaticResource LabelStyle}" />
                                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,10">
            <TextBlock Text="{Binding IsBusy, StringFormat=Busy: {0}}" Foreground="{DynamicResource TextSecondaryBrush}" />
        </Border>
    </Grid>
</Window>
