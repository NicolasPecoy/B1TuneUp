<Window x:Class="B1TuneUp.Modules.LanguageSelectorUi.LanguageSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B1TuneUp - Language Selector"
        Width="460"
        Height="260"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B1TuneUp;component/Resources/B1Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}" Padding="24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="B1TuneUp · Language Selector"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold" />
                <TextBlock Text="Define el idioma utilizado por todas las ventanas de TuneUp."
                           Foreground="#CCFFFFFF"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="24"
                Style="{StaticResource B1CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Selecciona un idioma" Style="{StaticResource LabelTextBlockStyle}" />
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage}" />
                <Button Content="Guardar"
                        Width="140"
                        Command="{Binding SaveCommand}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,12,0,0"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
